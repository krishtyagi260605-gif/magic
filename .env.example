APP_NAME=magic
DRY_RUN_DEFAULT=true

# LLM (LangChain) — chat model
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Keep model loaded in VRAM between requests (faster follow-ups)
OLLAMA_KEEP_ALIVE=15m

# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# Router uses a small token budget for speed (OpenAI only)
# OPENAI_ROUTER_MAX_TOKENS=380

# LlamaIndex embeddings — must match what you run locally
# For Ollama: run `ollama pull nomic-embed-text` (or your chosen embed model)
EMBEDDING_PROVIDER=google
GOOGLE_EMBEDDING_MODEL=models/embedding-001
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Indexed notes (comma-separated). Default if empty: ~/Documents/MagicNotes
# MAGIC_INDEX_PATHS=/Users/you/Documents/MagicNotes,/Users/you/Notes

# Persisted vector DB + fallback data (defaults to ~/.magic)
# MAGIC_DATA_DIR=/Users/you/.magic
# Desktop project workspace (default if empty: ~/Desktop/MagicProjects)
# MAGIC_WORKSPACE_ROOT=/Users/you/Desktop/MagicProjects

# RAG
RAG_TOP_K=5
RAG_RESPONSE_MODE=compact

# Voice (Whisper API — same key as OpenAI)
# OPENAI_API_KEY=

# Full desktop automation (mouse/keyboard). Requires Accessibility for the host app (Terminal/Cursor).
DESKTOP_AUTOMATION_ENABLED=true
DESKTOP_FAILSAFE=true
DESKTOP_PAUSE_SECONDS=0.08
DESKTOP_MAX_OPS_PER_PLAN=120
